mainmenu "Gateway Configuration"

config UART_0_ENABLE
    bool "Enable UART 0 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE && GPIO && PM_DEVICE && POLL
    help
      Enable the UART 0 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.

config UART_1_ENABLE
    bool "Enable UART 1 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE && GPIO && PM_DEVICE && POLL
    help
      Enable the UART 1 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.


config REBOOT_SIM7000E_ON_RESET
  bool "Select this to reset the SIM7000E module on reboot"
  help
    Select this option to reset the SIM7000E module on reboot. This option should be turned of in production.

config SEMCON_DEMO_MODE
  bool "Select this to enable the SEMCON demo mode"
  help
    Select this option to enable the SEMCON demo mode. This option should be turned of in production.

source "Kconfig.zephyr"