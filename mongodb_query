db.getCollection('TestData').aggregate(
  [
    {
      $match: {
        server_time: { $exists: true },
        data: { $exists: true }
      }
    },
    { $sort: { server_time: -1 } },
    { $unwind: '$data' },
    {
      $project: {
        id: '$data.id',
        server_time: 1,
        timestamp: '$data.t',
        humidity: '$data.mV_1',
        battery: '$data.mV_2'
      }
    }
  ],
  { maxTimeMS: 60000, allowDiskUse: true }
);