mainmenu "UART Configuration"

config UART_1_ENABLE
    bool "Enable UART 1 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE && GPIO && PM_DEVICE && POLL
    help
      Enable the UART 1 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.

config UART_0_ENABLE
    bool "Enable UART 0 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE && GPIO && PM_DEVICE && POLL
    help
      Enable the UART 0 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.

  config FLASH_CURRENT_TIMESTAMP
    bool "Current Unix timestamp"
    default n
    help
      If y flashes the current timestamp in unix format to the device using cmake.

source "Kconfig.zephyr"