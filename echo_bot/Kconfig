mainmenu "echo_bot_demo"

choice
	prompt "Use retention"
	optional

config APP_USE_NRF_RETENTION
	bool "Use state retention in system off using nRF POWER"
	depends on SOC_COMPATIBLE_NRF52X && CRC
	help
	  On some Nordic chips this application supports retaining
	  memory while in system off using POWER peripheral.
	  Select this to enable the feature.

config APP_USE_RETAINED_MEM
	bool "Use state retention in system off using retained_mem driver"
	depends on RETAINED_MEM

endchoice


config UART_1_ENABLE
    bool "Enable UART 1 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE
    help
      Enable the UART 1 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.

config UART_0_ENABLE
    bool "Enable UART 0 driver"
    depends on UART_INTERRUPT_DRIVEN && UART_USE_RUNTIME_CONFIGURE
    help
      Enable the UART 0 driver for communication. This option is only
      available if both interrupt-driven UART and runtime configuration
      for UART are enabled.

source "Kconfig.zephyr"